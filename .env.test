# E2E test environment — never use in production.
# Playwright global setup creates coffee_test DB; app runs on 8799.
DATABASE_URL=postgresql://coffee:coffee@localhost:8788/coffee_test
NEXTAUTH_URL=http://localhost:8799
NEXTAUTH_SECRET=test-secret-for-e2e-tests-only-at-least-32-chars
ENABLE_DEV_USER=false
PORT=8799
